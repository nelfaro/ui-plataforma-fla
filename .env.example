# --- CLIENTE ---
VITE_CUSTOMER_NAME=Clases de Inglés con Fla
VITE_CUSTOMER_LOGO_URL=/logo-fla.svg
VITE_CUSTOMER_PRIMARY_COLOR=#FFEB00
VITE_CUSTOMER_SECONDARY_COLOR=#FF1493

# --- PROXY BACKEND ---
# En producción (EasyPanel): /api  (nginx enruta internamente al backend-proxy)
# En desarrollo local: http://localhost:3001/api
VITE_API_BASE_URL=/api

# Paths de los endpoints (el proxy añade el prefijo /webhook/ automáticamente)
VITE_N8N_WEBHOOK_LOGIN=/webhook/verificar_login
VITE_N8N_WEBHOOK_REGISTER=/webhook/registro_cliente
VITE_N8N_WEBHOOK_KPI=/webhook/get-kpis
VITE_N8N_WEBHOOK_ANALYTICS_WEEKLY=/webhook/get-analytics-weekly
VITE_N8N_WEBHOOK_ANALYTICS_DISTRIBUTION=/webhook/get-leads-distribution
VITE_N8N_WEBHOOK_ANALYTICS_FUNNEL=/api/v1/analytics/conversion-funnel
VITE_N8N_WEBHOOK_ANALYTICS_ORIGIN=/api/v1/analytics/leads/origin
VITE_N8N_WEBHOOK_ALUMNOS=/webhook/get-alumnos
VITE_N8N_WEBHOOK_LAST_FILE=/api/v1/documents/last
VITE_N8N_WEBHOOK_UPLOAD_RAG=/webhook/subir-stock-manual

# --- INTEGRACIONES EXTERNAS ---
VITE_CHATWOOT_URL=https://asistente-ia-fla-chatwoot.x5miqk.easypanel.host
VITE_WHATSAPP_URL=https://asistente-ia-fla-puentewhatsapp.x5miqk.easypanel.host

# --- GENERAL ---
VITE_API_TIMEOUT=30000
VITE_DEBUG_MODE=false
VITE_DOMAIN=clasesdeinglesconfla.escalia.com.ar

# --- BACKEND PROXY (solo para el servicio backend-proxy en EasyPanel) ---
# N8N_BASE_URL=https://asistente-ia-fla-n8n.x5miqk.easypanel.host
# API_KEY=tu-api-key-aqui
# PORT=3001
