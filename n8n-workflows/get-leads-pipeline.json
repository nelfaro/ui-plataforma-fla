    {
      "parameters": {
        "query": "SELECT \n  id, \n  nombre, \n  whatsapp, \n  estado, \n  estado_motivo, \n  estado_fecha,\n  nivel, \n  origen, \n  lead_tipo, \n  objetivo, \n  resumen, \n  tags,\n  primera_consulta, \n  ultimo_contacto, \n  completitud\nFROM alumnos\nWHERE ($1::text IS NULL OR estado = $1)\n  AND ($2::text IS NULL OR origen = $2)\n  AND ($3::text IS NULL OR lead_tipo = $3)\nORDER BY ultimo_contacto DESC NULLS LAST\nLIMIT 100",
        "options": {}
      },
