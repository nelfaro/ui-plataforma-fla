    {
      "parameters": {
        "jsCode": "const body = $input.all()[0].json;\nconst { id, ...updates } = body;\n\nconst setClauses = [];\nfor (const [key, value] of Object.entries(updates)) {\n  if (value !== undefined && value !== null) {\n    if (typeof value === 'string') {\n      setClauses.push(`${key} = '${value.replace(/'/g, \"''\")}`);\n    } else {\n      setClauses.push(`${key} = ${value}`);\n    }\n  }\n}\n\nconst query = `UPDATE horarios SET ${setClauses.join(', ')}, updated_at = NOW() WHERE id = ${id} RETURNING *;`;\n\nreturn [{\n  json: {\n    query\n  }\n}];"
      },
      "id": "arma_query",
      "name": "Build Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
