    {
      "parameters": {
        "jsCode": "const horarios = $('obtener horarios').all().map(row => {\n  const h = row.json;\n  return {\n    ...h,\n    ocupacion_porcentaje: Math.round((h.cupo_actual / h.cupo_max) * 100),\n    cupos_libres: h.cupo_max - h.cupo_actual\n  };\n});\n\nreturn [{\n  json: {\n    success: true,\n    items: horarios\n  }\n}];"
      },
