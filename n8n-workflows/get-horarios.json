      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst { categoria } = input;\n\nlet query = `SELECT id, nombre, tipo, nivel, categoria, dia_1, dia_2, \n       hora_inicio, hora_fin, cupo_max, cupo_actual, precio_mensual, \n       descripcion, activo, created_at, updated_at\nFROM horarios\nWHERE activo = TRUE`;\n\n// Agregar filtro por categoría si se proporciona\nif (categoria) {\n  query += ` AND categoria = '${categoria}'`;\n}\n\nquery += ` ORDER BY nombre ASC;`;\n\nreturn [{\n  json: {\n    query\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
