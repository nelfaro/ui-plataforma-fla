    {
      "parameters": {
        "jsCode": "const { categoria, segmento } = $input.first().json;\n\nlet query = 'SELECT id, categoria, segmento, titulo, contenido, activo, created_at, updated_at FROM conocimiento_academia WHERE activo = true';\n\nif (categoria) {\n  query += ` AND categoria = '${categoria}'`;\n}\nif (segmento) {\n  query += ` AND segmento = '${segmento}'`;\n}\n\nquery += ' ORDER BY categoria, segmento, titulo';\n\nreturn [{\n  json: { query }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        50
      ],
      "id": "build-select-query",
      "name": "Build SELECT Query"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "= {{ $json.query }}"
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        200,
        50
      ],
      "id": "execute-select",
      "name": "Execute SELECT"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.first().json || [];\nreturn [{\n  json: {\n    items: rows,\n    total: rows.length\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        50
      ],
      "id": "format-select-response",
      "name": "Format Response"
    },
    {
      "parameters": {
        "jsCode": "const { categoria, segmento, titulo, contenido, activo } = $input.first().json.body;\n\nif (!titulo || !contenido) {\n  throw new Error('titulo y contenido son requeridos');\n}\n\nconst query = `INSERT INTO conocimiento_academia (categoria, segmento, titulo, contenido, activo) VALUES ('${categoria}', '${segmento}', '${titulo.replace(/'/g, \"''\")}', '${contenido.replace(/'/g, \"''\")}', ${activo !== false ? 'true' : 'false'}) RETURNING *`;\n\nreturn [{\n  json: { query }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        250
      ],
      "id": "build-insert-query",
      "name": "Build INSERT Query"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "= {{ $json.query }}"
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        200,
        250
      ],
      "id": "execute-insert",
      "name": "Execute INSERT"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json?.[0];\nif (!item) throw new Error('Error al crear item');\nreturn [{\n  json: {\n    id: item.id,\n    categoria: item.categoria,\n    segmento: item.segmento,\n    titulo: item.titulo,\n    created_at: item.created_at\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        250
      ],
      "id": "format-insert-response",
      "name": "Format Response"
    },
    {
      "parameters": {
        "jsCode": "const { id, categoria, segmento, titulo, contenido, activo } = $input.first().json.body;\n\nif (!id) throw new Error('id es requerido');\nif (!titulo || !contenido) throw new Error('titulo y contenido son requeridos');\n\nconst query = `UPDATE conocimiento_academia SET categoria = '${categoria}', segmento = '${segmento}', titulo = '${titulo.replace(/'/g, \"''\")}', contenido = '${contenido.replace(/'/g, \"''\")}', activo = ${activo !== false ? 'true' : 'false'}, updated_at = NOW() WHERE id = ${id} RETURNING *`;\n\nreturn [{\n  json: { query }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        450
      ],
      "id": "build-update-query",
      "name": "Build UPDATE Query"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "= {{ $json.query }}"
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        200,
        450
      ],
      "id": "execute-update",
      "name": "Execute UPDATE"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json?.[0];\nif (!item) throw new Error('Item no encontrado');\nreturn [{\n  json: {\n    id: item.id,\n    categoria: item.categoria,\n    segmento: item.segmento,\n    titulo: item.titulo,\n    updated_at: item.updated_at\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        450
      ],
      "id": "format-update-response",
      "name": "Format Response"
    },
    {
      "parameters": {
        "jsCode": "const path = $input.first().json.path;\nconst id = path.split('/').pop();\n\nif (!id || isNaN(id)) throw new Error('id inválido');\n\nconst query = `DELETE FROM conocimiento_academia WHERE id = ${id} RETURNING id`;\n\nreturn [{\n  json: { query }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        650
      ],
      "id": "build-delete-query",
      "name": "Build DELETE Query"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "= {{ $json.query }}"
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        200,
        650
      ],
      "id": "execute-delete",
      "name": "Execute DELETE"
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nif (!result || result.length === 0) throw new Error('Item no encontrado');\nreturn [{\n  json: { id: result[0].id, deleted: true }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        650
      ],
      "id": "format-delete-response",
      "name": "Format Response"
    }
