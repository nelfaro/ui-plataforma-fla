      "id": "webhook-conocimiento",
      "name": "Webhook",
      "webhookId": "conocimiento-crud"
    },
    {
      "parameters": {
        "jsCode": "const method = $input.first().json.$request?.method || 'GET';\nconst path = $input.first().json.$request?.path || '';\nconst body = $input.first().json.body || {};\nconst query = $input.first().json.query || {};\n\nreturn [{\n  json: {\n    method,\n    path,\n    body,\n    query,\n    categoria: query.categoria || body.categoria,\n    segmento: query.segmento || body.segmento,\n    id: path.split('/').pop()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        200
      ],
      "id": "parse-request",
      "name": "Parse Request"
    },
